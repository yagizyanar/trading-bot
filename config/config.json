{
  "max_open_trades": 15,
  "stake_currency": "USDT",
  "stake_amount": "unlimited",
  "tradable_balance_ratio": 0.75,
  "fiat_display_currency": "",
  "dry_run": true,
  "dry_run_wallet": 10000,
  "cancel_open_orders_on_exit": false,
  "trading_mode": "futures",
  "margin_mode": "isolated",
  "timeframe": "15m",
  "unfilledtimeout": {
    "entry": 10,
    "exit": 10,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },
  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0.0,
    "check_depth_of_market": {
      "enabled": false,
      "bids_to_ask_delta": 1
    }
  },
  "exit_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },
  "exchange": {
    "name": "binance",
    "key": "${BINANCE_API_KEY}",
    "secret": "${BINANCE_SECRET_KEY}",
    "ccxt_config": {},
    "ccxt_async_config": {},
    "pair_whitelist": [
      "SOL/USDT:USDT",
      "AVAX/USDT:USDT",
      "LINK/USDT:USDT",
      "DOT/USDT:USDT",
      "POL/USDT:USDT",
      "INJ/USDT:USDT",
      "ARB/USDT:USDT",
      "OP/USDT:USDT",
      "APT/USDT:USDT",
      "SUI/USDT:USDT",
      "NEAR/USDT:USDT",
      "S/USDT:USDT",
      "ATOM/USDT:USDT",
      "SAND/USDT:USDT",
      "MANA/USDT:USDT",
      "AXS/USDT:USDT",
      "DYDX/USDT:USDT",
      "GMX/USDT:USDT",
      "WIF/USDT:USDT",
      "1000BONK/USDT:USDT",
      "1000PEPE/USDT:USDT",
      "FET/USDT:USDT",
      "RENDER/USDT:USDT",
      "TAO/USDT:USDT"
    ],
    "pair_blacklist": []
  },
  "pairlists": [
    {"method": "StaticPairList"}
  ],
  "freqai": {
    "enabled": true,
    "purge_old_models": 2,
    "train_period_days": 180,
    "backtest_period_days": 7,
    "live_retrain_hours": 24,
    "identifier": "freqai_sentiment_v1",
    "feature_parameters": {
      "include_timeframes": ["1h", "4h"],
      "include_corr_pairlist": ["BTC/USDT:USDT", "ETH/USDT:USDT"],
      "label_period_candles": 24,
      "include_shifted_candles": 2,
      "DI_threshold": 0.9,
      "weight_factor": 0.9,
      "principal_component_analysis": false,
      "use_SVM_to_remove_outliers": true,
      "indicator_periods_candles": [10, 20]
    },
    "data_split_parameters": {
      "test_size": 0.25,
      "shuffle": false
    },
    "model_training_parameters": {
      "n_estimators": 800,
      "learning_rate": 0.02,
      "task_type": "CPU"
    }
  },
  "leverage": 2,
  "stoploss": -0.05,
  "minimal_roi": {"0": 100},
  "trailing_stop": true,
  "trailing_stop_positive": 0.02,
  "trailing_stop_positive_offset": 0.03,
  "trailing_only_offset_is_reached": true,
  "use_exit_signal": true,
  "exit_profit_only": false,
  "exit_profit_offset": 0.0,
  "ignore_roi_if_entry_signal": false,
  "strategy": "FreqAISentimentStrategy",
  "strategy_path": "strategies/",
  "user_data_dir": "user_data/",
  "db_url": "sqlite:///user_data/tradesv3.sqlite",
  "initial_state": "running",
  "force_entry_enable": false,
  "internals": {
    "process_throttle_secs": 5
  },
  "bot_name": "trade-sentiment-markov",
  "telegram": {"enabled": false, "token": "disabled", "chat_id": "disabled"},
  "api_server": {
    "enabled": true,
    "listen_ip_address": "127.0.0.1",
    "listen_port": 8080,
    "verbosity": "error",
    "enable_openapi": false,
    "jwt_secret_key": "change-me-in-env",
    "ws_token": "change-me-in-env",
    "CORS_origins": ["http://localhost:5173"],
    "username": "freqtrader",
    "password": "change-me-in-env"
  }
}
